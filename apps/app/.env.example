# =============================================================================
# Environment variables for @ferri/app.
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# Runtime connection used by the Prisma client (@ferri/db). In production use
# the transaction-mode pooler (IPv4-only, serverless-friendly).
DATABASE_URL=

# Direct/session-mode connection used by the Prisma CLI for migrations and
# introspection.
DIRECT_URL=

# -----------------------------------------------------------------------------
# Hosts (proxy host routing)
# -----------------------------------------------------------------------------
# Device-facing API host — requests are rewritten into the /api folder.
API_HOST=

# Dashboard host — served as-is. Any other host resolves as a link domain
# (rewritten into /link/{host}).
APP_HOST=

# -----------------------------------------------------------------------------
# Matching
# -----------------------------------------------------------------------------
# Secret pepper for hashing client IPs before they enter the KV match store.
# Must be stable (rotating it breaks in-flight matches) and kept secret — IPv4
# has only ~4B values, so an unsalted hash is trivially reversible.
IP_HASH_PEPPER=

# -----------------------------------------------------------------------------
# Supabase (auth & storage) — public, exposed to the browser
# -----------------------------------------------------------------------------
# Project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Upstash Redis (KV match store) — REST API
# -----------------------------------------------------------------------------
# REST endpoint and token from the Upstash console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
